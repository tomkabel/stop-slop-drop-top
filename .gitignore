# =============================================================================
# Temporary test output files
test.txt
test2.txt
test3.txt
test-write.txt
test-output.txt
*.test.txt

# Browser detector outputs (cookie/session based - security sensitive)
gptzero.txt
zerogpt.txt
winston.txt
originality.txt
Verte.txt
detector_output.txt

# Results and output directories
results/
output/
outputs/
detection_results/
logs/

# JSON output files (except package.json)
!package.json
!tsconfig.json
!next.config.js

# Test reports
test-report/
coverage/


