# =============================================================================
# stop-slop-drop-top - AI Detection CLI Tool
# =============================================================================
# Comprehensive .gitignore for the AI detection testing project
# Includes Node.js CLI, Next.js web app, Python nodriver automation, and Kilo agents
# =============================================================================

# =============================================================================
# NODE.JS / NPM
# =============================================================================
node_modules/
dist/
build/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Environment variables (local overrides)
.env
.env.local
.env.development
.env.test
.env.production
.env.*.local

# npm/Node cache
.npm
.eslintcache
.node_repl_history
*.tgz

# Bundle outputs
*.bundle.js


# =============================================================================
# PYTHON / NODRIVER AUTOMATION
# =============================================================================
# Virtual environments
.venv/
venv/
ENV/
env/
.venv3*/

# Python cache and compiled files
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
dist/
build/
*.egg

# pytest / testing
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/
coverage.xml
*.cover

# Ruff linter cache
.ruff_cache/
.ruff_cache.toml

