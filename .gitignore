*.whl
build/
develop-eggs/
eggs/
.eggs/
lib64/
sdist/
var/
wheels/
*.egg-info/

# Jupyter Notebook
.ipynb_checkpoints/
.ipynb_checkpoints


# =============================================================================
# NEXT.JS / WEB FRAMEWORK
# =============================================================================
# Next.js build output
web/.next/
next-env.d.ts
next.config.js
next.config.mjs
next.config.ts

# Vercel deployment
