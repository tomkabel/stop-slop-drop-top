# =============================================================================
# OPERATING SYSTEM FILES
# =============================================================================
# macOS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Linux
*~

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
*.stackdump
[Dd]esktop.ini
$RECYCLE.BIN/

# Nautilus (GNOME)
.nautilus/
.metadata_never_index

# Google Drive (macOS)
.appledoublefile


# =============================================================================
# SECURITY-SENSITIVE FILES (MUST NEVER BE COMMITTED)
# =============================================================================
# NOTE: These exclusions are INTENTIONAL for security reasons.
# Browser automation (nodriver) may store session cookies that could
# expose authentication to AI detector services. These files must
# NEVER be committed to prevent credential leakage.

# Cookie/session files from browser automation
gptzero.txt
zerogpt.txt
winston.txt
originality.txt
Verte.txt
*.cookie
*.session
cookies.txt
cookies.json

# Cookie/session directories
cookies/
session_data/
browser_sessions/
auth_data/

# Credentials and secrets
credentials.json
secrets/
keys/
*.key
*.pem
*.cert
*.p12

# Environment files with secrets (override the above patterns only for .env)
.env
.env.local
.env.*.local
.env.development.local
.env.test.local
.env.production.local


# =============================================================================
# BUILD OUTPUTS / COMPILATION
# =============================================================================
# General build outputs
*.o
*.obj
*.exe
*.dll
*.so
*.dylib

# Go
*.test
*.out
vendor/

# Rust
target/
Cargo.lock


# =============================================================================
# TEMPORARY / DEVELOPMENT FILES
# =============================================================================
# Debug and temporary files
*.tmp
*.temp
*.bak
*.orig
*.rej
*.patch

# Temporary directories
tmp/
temp/
temporary/

# Backup files
*~


# =============================================================================
# GIT
# =============================================================================
# Git internals
.git/
.gitignore  (keep this file!)
.gitattributes
.gitmodules

# Git hooks (can be custom, so usually keep but ignore output)
.git/hooks/
.git/refs/

# Git stash
.git_stash


# =============================================================================
# GITHUB ACTIONS / CI/CD
# =============================================================================
# GitHub Actions workflow artifacts (in the repo root)
!.github/

# Build artifacts from CI
.github/workflows/.cache/


# =============================================================================
# KEEP THESE FILES/DIRECTORIES
# =============================================================================
# The following files are intentionally tracked in git:

# Sample test data - legitimate AI/human text samples
!/samples/
samples/*
!samples/human-text.txt
!samples/ai-text.txt

# Test fixtures - keep test fixtures for testing
!/tests/fixtures/
tests/fixtures/*
!tests/fixtures/.gitkeep

# Kilo configuration (keep the config, ignore cache)
!.kilocode/
!.kilocode/config.yaml
!.kilocode/skills/
!.kilocode/skills/slop-reviewer/
!.kilocode/skills/slop-reviewer/SKILL.md
!.kilocode/skills/stop-slop/
!.kilocode/skills/stop-slop/SKILL.md

# GitHub Actions workflows
!.github/workflows/

# Documentation (keep these markdown files)
!/AI-DETECTION.md
!/SKILL.md
!/README.md
!/AGENTS.md


# =============================================================================
# EXTRAS
# =============================================================================
# Terraform (if used)
*.tfstate
*.tfstate.*
.terraform/
.terraform.lock.*

# Docker (if used)
.docker/
docker-compose.override.yml

# Vagrant (if used)
.vagrant/
*.vagrant/
.vagrant.d/

