.vercel/
.vercel.json

# TypeScript build info
web/tsconfig.tsbuildinfo
*.tsbuildinfo

# Build outputs
web/out/
web/build/
web/public/build/
.web/

# Storybook
web/.storybook/build/
web/storybook-static/

# Turbopack
.turbo/

# React cache
web/.cache/


# =============================================================================
# KILO / AI AGENT CONFIGURATION
# =============================================================================
# Kilo agent state and cache
.kilocode/cache/
.kilocode/state.json
.kilocode/.env

# Agent logs (may contain sensitive data)
.kilocode/logs/
*.agent.log

# Skill cache
.kilocode/skills/*/cache/
.kilocode/skills/*/.temp/


# =============================================================================
# BROWSER AUTOMATION / STEALTH BROWSER
# =============================================================================
# Browser user data (contains cookies, sessions - security sensitive)
user_data/
.userdata/
chromium_user_data/
browser_profiles/

# Element clone data (temporary browser automation output)
element_clones/
element_data/
browser_snapshots/

# MCP (Model Context Protocol) external projects
stealth-browser-mcp/
mcp-server-*/

# Browser logs
browser.log
browser_debug.log
*.har

# CDP (Chrome DevTools Protocol) logs
cdp_*.log


# =============================================================================
